rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Card Catalog: read-only reference data. Any signed-in device (including
    // anonymous auth) may read it; only the Admin SDK seed script writes it.
    match /catalogs/{catalogId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
