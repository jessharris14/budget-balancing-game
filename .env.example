# Firebase Web SDK config — copy this file to .env and fill in real values.
# Get these from Firebase Console > Project Settings > General > Your apps > Web app.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Realtime Database URL — Firebase Console > Realtime Database > top of the data viewer.
# e.g. https://<project-id>-default-rtdb.firebaseio.com or a region-specific *.firebasedatabase.app URL
VITE_FIREBASE_DATABASE_URL=
