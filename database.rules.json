{
  "rules": {
    "sessions": {
      "$code": {
        ".read": "auth != null",
        ".write": "auth != null && !data.exists()",

        "phase": {
          ".write": "auth != null && auth.uid === root.child('sessions').child($code).child('facilitatorId').val()"
        },
        "clock": {
          ".write": "auth != null && auth.uid === root.child('sessions').child($code).child('facilitatorId').val()"
        },

        "commissions": {
          "$commissionId": {
            "name": {
              ".write": "auth != null && !data.exists()"
            },
            "members": {
              "managerAdminId": {
                ".write": "auth != null && !data.exists() && newData.val() === auth.uid",
                ".validate": "newData.val() === auth.uid"
              },
              "chairId": {
                ".write": "auth != null && !data.exists() && auth.uid === root.child('sessions').child($code).child('facilitatorId').val()"
              },
              "commissionerIds": {
                "$uid": {
                  ".write": "auth != null && auth.uid === $uid",
                  ".validate": "newData.val() === true"
                }
              }
            },
            "chairRoll": {
              ".write": "auth != null && auth.uid === root.child('sessions').child($code).child('facilitatorId').val()"
            },
            "priority": {
              "selectedCardId": {
                ".write": "auth != null && auth.uid === root.child('sessions').child($code).child('facilitatorId').val()"
              }
            },
            "activeChallenge": {
              ".write": "auth != null && auth.uid === root.child('sessions').child($code).child('facilitatorId').val()"
            },
            "challengesApplied": {
              "$cardId": {
                ".write": "auth != null && auth.uid === root.child('sessions').child($code).child('facilitatorId').val()",
                ".validate": "newData.val() === true"
              }
            },

            "ledger": {
              ".write": "auth != null && (auth.uid === root.child('sessions').child($code).child('commissions').child($commissionId).child('members').child('managerAdminId').val() || auth.uid === root.child('sessions').child($code).child('facilitatorId').val())"
            },
            "cardsInPlay": {
              "$cardId": {
                ".write": "auth != null && auth.uid === root.child('sessions').child($code).child('commissions').child($commissionId).child('members').child('managerAdminId').val()"
              }
            },
            "cardsLockedOut": {
              "$cardId": {
                ".write": "auth != null && auth.uid === root.child('sessions').child($code).child('commissions').child($commissionId).child('members').child('managerAdminId').val()"
              }
            },
            "challengeLedgerAppliedAt": {
              ".write": "auth != null && (auth.uid === root.child('sessions').child($code).child('commissions').child($commissionId).child('members').child('managerAdminId').val() || auth.uid === root.child('sessions').child($code).child('facilitatorId').val())"
            },
            "chairFreeCardUsed": {
              ".write": "auth != null && auth.uid === root.child('sessions').child($code).child('commissions').child($commissionId).child('members').child('managerAdminId').val() && data.val() === false && newData.val() === true"
            }
          }
        },

        "publicHearingSpeakers": {
          "$uid": {
            ".write": "auth != null && auth.uid === $uid"
          }
        },

        "participants": {
          "$uid": {
            ".write": "auth != null && auth.uid === $uid",
            ".validate": "newData.child('uid').val() === $uid"
          }
        }
      }
    }
  }
}
